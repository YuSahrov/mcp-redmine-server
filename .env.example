# Redmine MCP Server Configuration
#
# IMPORTANT: This file should be copied to each of your Claude project directories
# as .env to configure project-specific Redmine settings.
#
# How it works:
# 1. Copy this file to your project directory: cp .env.example /path/to/your/project/.env
# 2. Edit the .env file in your project with your project-specific REDMINE_PROJECT_ID
# 3. The MCP server will automatically load the .env from the directory where Claude is running
#
# Example setup:
#   Project A: /projects/projectA/.env -> REDMINE_PROJECT_ID=123
#   Project B: /projects/projectB/.env -> REDMINE_PROJECT_ID=456
#   Project C: /projects/projectC/.env -> REDMINE_PROJECT_ID=789

# Required: Your Redmine API key
REDMINE_API_KEY=your_api_key_here

# Optional: Redmine server URL (default: https://3cad.tech)
REDMINE_BASE_URL=https://3cad.tech

# Optional: Project ID - CHANGE THIS FOR EACH PROJECT
REDMINE_PROJECT_ID=8

# Optional: Project identifier - CHANGE THIS FOR EACH PROJECT
REDMINE_PROJECT_IDENTIFIER=cad-tech
